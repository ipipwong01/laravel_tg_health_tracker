APP_NAME="Telegram Health Tracker"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_DATABASE=telegram_health_tracker
DB_USERNAME=telegram_health
DB_PASSWORD=CHANGE_TO_A_LONG_RANDOM_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_TO_A_DIFFERENT_LONG_RANDOM_ROOT_PASSWORD

TELEGRAM_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN
TELEGRAM_ALLOWED_USER_IDS=PASTE_YOUR_NUMERIC_TELEGRAM_ID
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_DEFAULT_GLUCOSE_UNIT=mmol/L
TELEGRAM_REPLY_TO_UNAUTHORIZED=true
TELEGRAM_PRIVATE_CHATS_ONLY=true

APP_PORT=8080
